package com.contract.master.rules;

import com.contract.master.contract.domain.model.Contract;
import java.util.List;
import java.math.BigDecimal;

global java.util.List violations;

rule "Large Contract Review"
when
    $c : Contract(amount != null && amount.amount != null)
    eval($c.getAmount().getAmount().compareTo(new BigDecimal("1000000")) > 0)
then
    violations.add("CRITICAL: Contract amount " + $c.getAmount().getAmount() + " exceeds limit, requires manual legal review");
end
